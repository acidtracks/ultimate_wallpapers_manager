[Unit]
Description=Ultimate Wallpapers Manager — watcher (MPRIS + Hyprland)
After=default.target swww-daemon.service
Wants=swww-daemon.service

[Service]
Type=simple
ExecStart=/usr/bin/python3 -m uwm watch
Environment=PATH=/usr/local/bin:/usr/bin:/bin:%h/.local/bin
Environment=WAYLAND_DISPLAY=wayland-1
Environment=DISPLAY=:0
Restart=always
RestartSec=5s

[Install]
WantedBy=graphical-session.target
